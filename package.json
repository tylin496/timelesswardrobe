{
  "name": "timeless-wardrobe",
  "private": true,
  "type": "module",
  "scripts": {
    "css:build": "node scripts/build-css.mjs",
    "lint:insets": "node scripts/check-safe-area-insets.mjs",
    "check:urls": "node scripts/check-public-urls.mjs",
    "check:id-drift": "node scripts/check-catalogue-id-drift.mjs",
    "check:data": "node scripts/check-data-integrity.mjs",
    "check:css": "node scripts/check-css-build.mjs",
    "check": "node scripts/check-safe-area-insets.mjs && node scripts/check-public-urls.mjs && node scripts/check-catalogue-id-drift.mjs && node scripts/check-data-integrity.mjs && node scripts/check-css-build.mjs",
    "predev": "node scripts/build-css.mjs && npm run images:rebuild",
    "og:build": "node scripts/build-og-image.mjs",
    "images:center": "node scripts/center-cutouts.mjs",
    "images:cutouts": "node scripts/generate-wardrobe-cutout-thumbs.mjs",
    "images:rebuild": "node scripts/center-cutouts.mjs && node scripts/generate-wardrobe-cutout-thumbs.mjs",
    "build": "node scripts/check-safe-area-insets.mjs && node scripts/build-css.mjs && npm run images:rebuild && node scripts/build-og-image.mjs && node scripts/build-static-dist.mjs && node scripts/build-item-og-pages.mjs",
    "og:items": "node scripts/build-item-og-pages.mjs",
    "dev": "node scripts/tw-dev-server.mjs",
    "dev:monitor": "node scripts/tw-dev-monitor.mjs",
    "check:showcase": "node scripts/check-showcase-order.mjs",
    "db:backup": "node scripts/backup.mjs",
    "db:freeze-catalogue": "node scripts/freeze_catalogue_from_supabase.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "image-size": "^2.0.2",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.3.0"
  }
}
