{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "images": {
    "sizes": [640, 828, 1080, 1200, 1920, 2048],
    "minimumCacheTTL": 31536000
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff2?|svg|ico|png|jpg|jpeg|webp|avif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/collection/additem", "destination": "/collection", "permanent": false },
    { "source": "/collection/editor", "destination": "/collection", "permanent": false },
    { "source": "/item/:id/edit", "destination": "/item?id=:id&edit=1", "permanent": false },
    { "source": "/collection/login", "destination": "/login", "permanent": false }
  ],
  "rewrites": [
    { "source": "/outfit/:slug", "destination": "/" },
    { "source": "/editorial/:slug", "destination": "/editorial" },
    { "source": "/collection/item.html", "destination": "/item" },
    { "source": "/collection/item", "destination": "/item" },
    { "source": "/collection/:division", "destination": "/collection" },
    { "source": "/favicon.ico", "destination": "/favicon.png" }
  ]
}
