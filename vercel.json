{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/collection/additem", "destination": "/collection.html", "permanent": false },
    { "source": "/collection/editor", "destination": "/collection.html", "permanent": false },
    { "source": "/item/:id/edit", "destination": "/item.html?id=:id&edit=1", "permanent": false }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/collection/item.html", "destination": "/item.html" },
    { "source": "/collection/item", "destination": "/item.html" },
    { "source": "/collection", "destination": "/collection.html" },
    { "source": "/collection/:division", "destination": "/collection.html" },
    { "source": "/favicon.ico", "destination": "/favicon.png" }
  ]
}
